# Comma-separated additional web origins allowed to call Edge Functions.
# cosearch.club and local Vite origins on port 5173 are already allowed.
ALLOWED_ORIGINS=https://preview.example

# Club email delivery. Keep real values in Supabase Edge Function secrets and
# an untracked local env file; never commit them here.
RESEND_API_KEY=re_example
CLUB_EMAIL_FROM=cosearch <notifications@cosearch.club>
CLUB_EMAIL_CRON_SECRET=replace-with-at-least-32-random-characters
CLUB_EMAIL_APP_URL=https://cosearch.club
# Optional local/test override. Production should use the default Resend URL.
# RESEND_API_URL=http://host.docker.internal:8787/emails
